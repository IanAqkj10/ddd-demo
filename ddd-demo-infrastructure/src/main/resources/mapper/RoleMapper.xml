<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.example.ddd.infrastructure.iam.mapper.RoleMapper">

    <select id="selectByCode" resultType="com.example.ddd.infrastructure.iam.dataobject.RoleDO">
        SELECT role_id, code, name, permissions, created_at, last_updated_at
        FROM t_iam_role
        WHERE code = #{code}
    </select>

</mapper>
